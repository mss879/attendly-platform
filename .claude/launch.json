{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "attendly-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "attendly-prod",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start", "--", "-p", "3001"],
      "port": 3001
    },
    {
      "name": "attendly-prod-utc",
      "runtimeExecutable": "env",
      "runtimeArgs": ["TZ=UTC", "npm", "run", "start", "--", "-p", "3002"],
      "port": 3002
    }
  ]
}
